# 프로덕션 환경 변수 (GitHub Secrets / 서버 .env.production)
# 복사: cp .env.production.example .env.production

# ── Database ──
POSTGRES_USER=ocd
POSTGRES_PASSWORD=change-strong-password
POSTGRES_DB=ocd_budget

# ── API ──
JWT_ACCESS_SECRET=change-min-32-char-random-access-secret
JWT_REFRESH_SECRET=change-min-32-char-random-refresh-secret
CORS_ORIGIN=https://your-domain.com
API_PUBLIC_URL=https://api.your-domain.com
API_PORT=4000

# ── Web (빌드 시 ARG로 주입) ──
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1
WEB_PORT=3000

# ── Docker images (GHCR) ──
# API_IMAGE=ghcr.io/YOUR_GITHUB_USER/ocd-api:latest
# WEB_IMAGE=ghcr.io/YOUR_GITHUB_USER/ocd-web:latest

# ── S3 (선택, 없으면 로컬 uploads 볼륨) ──
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=ap-northeast-2
